# ProxyAPI (https://proxyapi.ru/docs/overview)
PROXYAPI_KEY=your_proxyapi_key_here

# Telegram bot (опционально; для production часто false)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ENABLED=true

# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# App
BOT_MODE=rag
DEFAULT_VOICE=alloy
LOG_LEVEL=INFO

# Production overrides (раскомментируйте на сервере):
# FLASK_HOST=0.0.0.0
# FLASK_DEBUG=false
# TELEGRAM_ENABLED=false
